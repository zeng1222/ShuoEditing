---
import { stegaClean } from "@sanity/client/stega";
import type { Work } from "../lib/types";

interface Props {
  works: Work[];
}

const { works } = Astro.props;

const worksData = stegaClean(
  works.map((w) => ({
    slug: w.slug,
    title: w.title,
    client: w.client ?? "",
    categoryLabel: w.category?.name ?? "",
    format: w.format ?? "vertical",
    youtubeId: w.youtubeId,
    excerpt: w.excerpt ?? "",
    description: w.description ?? "",
    role: w.role ?? "",
    credits: w.credits ?? [],
  })),
);
---

<div
  id="work-modal"
  class="modal-backdrop"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
>
  <button
    type="button"
    id="modal-close"
    aria-label="關閉"
    class="fixed top-4 right-4 z-20 flex h-10 w-10 items-center justify-center rounded-full bg-paper/10 text-paper transition-colors hover:bg-paper/20 md:top-6 md:right-6 md:h-12 md:w-12"
  >
    <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
      <path d="M5 5 L15 15 M15 5 L5 15" stroke="currentColor" stroke-width="1.5" />
    </svg>
  </button>

  <div class="modal-content min-h-full w-full py-12 px-5 md:py-16 md:px-10">
    <div
      id="modal-grid"
      class="mx-auto grid max-w-6xl gap-8 md:gap-10 lg:grid-cols-[auto_1fr] lg:gap-14"
    >
      {/* Video container — sizing switches via JS based on format */}
      <div id="modal-video-wrap" class="mx-auto w-full">
        <div id="modal-video-mount"></div>
      </div>

      {/* Details */}
      <div class="text-paper">
        <p class="eyebrow text-paper/60">
          <span id="modal-category"></span>
        </p>
        <h2
          id="modal-title"
          class="display-2 mt-3 zh text-paper"
        >
        </h2>
        <p id="modal-client" class="mt-2 text-sm text-paper/70 zh md:text-base"></p>

        <div class="hairline mt-6 bg-paper/20"></div>

        <p id="modal-excerpt" class="mt-5 zh text-base text-paper/90 leading-relaxed md:text-lg"></p>
        <div
          id="modal-description"
          class="mt-5 space-y-4 leading-loose text-paper/75 zh text-sm md:text-base"
        >
        </div>

        <div
          id="modal-credits-wrap"
          class="mt-8 grid gap-6 sm:grid-cols-2 md:mt-10"
        >
          <div id="modal-role-wrap" class="hidden">
            <p class="eyebrow text-paper/60">Role</p>
            <p id="modal-role" class="mt-2 text-paper/90 zh text-sm md:text-base"></p>
          </div>
          <div id="modal-credits-list-wrap" class="hidden">
            <p class="eyebrow text-paper/60">Credits</p>
            <dl id="modal-credits-list" class="mt-2 space-y-1.5 text-sm"></dl>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script
  type="application/json"
  id="works-data"
  set:html={JSON.stringify(worksData)}
/>

<script is:inline>
  (function () {
    const modal = document.getElementById("work-modal");
    const closeBtn = document.getElementById("modal-close");
    const dataEl = document.getElementById("works-data");
    if (!modal || !dataEl) return;

    const works = JSON.parse(dataEl.textContent || "[]");

    function open(slug) {
      const w = works.find((x) => x.slug === slug);
      if (!w) return;

      document.getElementById("modal-category").textContent = w.categoryLabel;
      document.getElementById("modal-title").textContent = w.title;
      document.getElementById("modal-client").textContent = w.client || "";
      document.getElementById("modal-excerpt").textContent = w.excerpt || "";

      const descEl = document.getElementById("modal-description");
      descEl.innerHTML = "";
      (w.description || "")
        .split("\n\n")
        .filter(Boolean)
        .forEach((p) => {
          const para = document.createElement("p");
          para.textContent = p;
          descEl.appendChild(para);
        });

      const roleWrap = document.getElementById("modal-role-wrap");
      if (w.role) {
        document.getElementById("modal-role").textContent = w.role;
        roleWrap.classList.remove("hidden");
      } else {
        roleWrap.classList.add("hidden");
      }

      const creditsWrap = document.getElementById("modal-credits-list-wrap");
      const creditsList = document.getElementById("modal-credits-list");
      if (w.credits && w.credits.length) {
        creditsList.innerHTML = "";
        w.credits.forEach((c) => {
          const div = document.createElement("div");
          div.className = "flex gap-3";
          div.innerHTML = `<dt class="w-16 shrink-0 text-paper/50">${escape(c.label || "")}</dt><dd class="text-paper/90">${escape(c.name || "")}</dd>`;
          creditsList.appendChild(div);
        });
        creditsWrap.classList.remove("hidden");
      } else {
        creditsWrap.classList.add("hidden");
      }

      const mount = document.getElementById("modal-video-mount");
      const wrap = document.getElementById("modal-video-wrap");
      const grid = document.getElementById("modal-grid");
      mount.innerHTML = "";

      const isHorizontal = w.format === "horizontal";
      if (isHorizontal) {
        wrap.className = "w-full";
        grid.className =
          "mx-auto grid max-w-5xl gap-8 md:gap-10";
      } else {
        // Fixed widths avoid the CSS-grid `auto` + `w-full` zero-width bug
        wrap.className =
          "mx-auto w-full max-w-[320px] sm:max-w-[360px] lg:w-[380px] lg:max-w-none";
        grid.className =
          "mx-auto grid max-w-6xl gap-8 md:gap-10 lg:grid-cols-[380px_minmax(0,1fr)] lg:gap-14";
      }

      // Plain YouTube iframe (more reliable inside modal than lite-youtube)
      const aspectBox = document.createElement("div");
      aspectBox.style.position = "relative";
      aspectBox.style.width = "100%";
      aspectBox.style.aspectRatio = isHorizontal ? "16 / 9" : "9 / 16";
      aspectBox.style.background = "#000";
      aspectBox.style.borderRadius = "2px";
      aspectBox.style.overflow = "hidden";

      const iframe = document.createElement("iframe");
      iframe.src =
        "https://www.youtube-nocookie.com/embed/" +
        encodeURIComponent(w.youtubeId) +
        "?rel=0&modestbranding=1&playsinline=1";
      iframe.title = w.title;
      iframe.setAttribute(
        "allow",
        "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share",
      );
      iframe.setAttribute("allowfullscreen", "");
      iframe.setAttribute("referrerpolicy", "strict-origin-when-cross-origin");
      iframe.style.cssText =
        "position:absolute;top:0;left:0;width:100%;height:100%;border:0;display:block;";

      aspectBox.appendChild(iframe);
      mount.appendChild(aspectBox);

      modal.classList.add("is-open");
      modal.setAttribute("aria-hidden", "false");
      modal.scrollTop = 0;
      document.body.style.overflow = "hidden";
    }

    function close() {
      modal.classList.remove("is-open");
      modal.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      setTimeout(() => {
        const mount = document.getElementById("modal-video-mount");
        if (mount) mount.innerHTML = "";
      }, 300);
    }

    function escape(s) {
      return String(s)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;");
    }

    document.querySelectorAll(".work-trigger").forEach((btn) => {
      btn.addEventListener("click", () => {
        const slug = btn.getAttribute("data-work-slug");
        if (slug) open(slug);
      });
    });

    closeBtn?.addEventListener("click", close);
    modal.addEventListener("click", (e) => {
      if (e.target === modal) close();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && modal.classList.contains("is-open")) close();
    });
  })();
</script>
