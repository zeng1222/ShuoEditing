---
import type { Work } from "../lib/types";

interface Props {
  work: Work;
  index?: number;
}

const { work, index } = Astro.props;

const isHorizontal = work.format === "horizontal";

const cover =
  work.coverImage ||
  (isHorizontal
    ? `https://i.ytimg.com/vi/${work.youtubeId}/maxresdefault.jpg`
    : `https://i.ytimg.com/vi/${work.youtubeId}/hqdefault.jpg`);

const indexLabel =
  index !== undefined ? String(index + 1).padStart(2, "0") : null;
---

<button
  type="button"
  class="group work-trigger relative block w-full cursor-pointer text-left"
  data-work-slug={work.slug}
  data-category={work.category?.slug}
  data-format={work.format}
>
  <div
    class:list={[
      "relative overflow-hidden rounded-sm bg-ink/95",
      isHorizontal ? "aspect-video" : "aspect-[9/16]",
    ]}
  >
    <img
      src={cover}
      alt={work.title}
      loading="lazy"
      class="absolute inset-0 h-full w-full object-cover transition-transform duration-[800ms] ease-out group-hover:scale-[1.05]"
    />

    <div
      class="absolute inset-x-0 top-0 z-10 flex items-center justify-between bg-gradient-to-b from-black/45 to-transparent p-2.5 text-paper md:p-3.5"
    >
      {
        indexLabel ? (
          <span class="accent-serif text-xs md:text-sm">{indexLabel}</span>
        ) : (
          <span />
        )
      }
      <span class="text-[10px] uppercase tracking-[0.14em] text-paper/80 md:text-[11px]">
        {work.category?.name}
      </span>
    </div>

    <div
      class="absolute inset-0 z-10 flex items-center justify-center opacity-0 transition-opacity duration-500 group-hover:opacity-100"
    >
      <div
        class="flex h-12 w-12 items-center justify-center rounded-full bg-paper/95 shadow-xl backdrop-blur md:h-14 md:w-14"
      >
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
          <path d="M5 3 L17 10 L5 17 Z" fill="#141210" />
        </svg>
      </div>
    </div>

    <div
      class="absolute inset-x-0 bottom-0 z-10 bg-gradient-to-t from-black/85 via-black/35 to-transparent p-2.5 pb-3 md:p-3.5 md:pb-4"
    >
      <h3
        class:list={[
          "zh font-medium leading-snug text-paper",
          isHorizontal ? "text-base md:text-lg" : "text-[13px] md:text-sm",
        ]}
      >
        {work.title}
      </h3>
      {work.client && (
        <p
          class:list={[
            "mt-1 truncate text-paper/70",
            isHorizontal ? "text-xs md:text-sm" : "text-[10px] md:text-[11px]",
          ]}
        >
          {work.client}
        </p>
      )}
    </div>
  </div>
</button>
