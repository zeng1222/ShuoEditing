# ============================
# Sanity CMS
# ============================
# 等你建立 Sanity 專案後，把 Project ID 填進來
# 取得方式：https://www.sanity.io/manage → 你的專案 → settings → Project ID
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Viewer Token — Visual Editing 預覽用（讀取 drafts）
# Sanity Manage → API → Tokens → Add API token → 權限選 Viewer
SANITY_VIEWER_TOKEN=

# ============================
# Contact form (Resend)
# ============================
# 註冊 Resend：https://resend.com（每月 3,000 封免費）
# 1. 註冊後驗證你的 domain（或用 onboarding@resend.dev 測試）
# 2. 取得 API Key
RESEND_API_KEY=
CONTACT_TO_EMAIL=your-email@example.com
CONTACT_FROM_EMAIL=noreply@yourdomain.com
